# OpenRouter API Key — used for ALL AI model calls (Phase 1 Gemini + Phase 2 Grok + Compliance + Dev Prompt)
OPENROUTER_API_KEY=

# Server port
PORT=3001

# Allowed origins for CORS in production (comma-separated)
ALLOWED_ORIGINS=https://jservo.com,https://www.jservo.com

# Node environment
NODE_ENV=development
